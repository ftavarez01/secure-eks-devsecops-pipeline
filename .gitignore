# --- TERRAFORM ---
# Exclude local Terraform working directory (contains binaries and plugins specific to Fedora)
.terraform/

# Exclude Terraform state files (These contain sensitive infrastructure data in plain text)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Exclude dependency lock file
.terraform.lock.hcl

# --- VARIABLES & SECRETS ---
# Exclude files containing passwords, tokens, or private keys
*.tfvars
*.tfvars.json
terraform.tfvars

# --- LOGS & TEMPORARY FILES ---
# Exclude execution logs and local configuration overrides
*.log
.terraformrc
terraform.rc

# --- CLOUD & ENVIRONMENT ---
# Exclude local AWS credentials and virtual environments
.aws/
.env
.venv/
